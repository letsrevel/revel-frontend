# CI-only backend environment for the e2e release gate. No real secrets —
# Stripe values are injected by the workflow from org secrets at runtime.

# Prod-like, but NOT "production": DEPLOYMENT_ENVIRONMENT=production would
# enable SECURE_SSL_REDIRECT and break plain-HTTP CI traffic.
DEBUG=False
DEPLOYMENT_ENVIRONMENT=ci

# Required by settings (no defaults) — throwaway CI values.
SECRET_KEY=ci-only-django-secret-key-not-a-secret
SALT_KEY=ci-only-salt-key-not-a-secret
ALLOWED_HOSTS=localhost,127.0.0.1,backend
GOOGLE_SSO_STAFF_LIST=
GOOGLE_SSO_SUPERUSER_LIST=
TELEGRAM_STAFF_IDS=
TELEGRAM_SUPERUSER_IDS=

# Compose-network service names.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=revel
DB_USER=revel
DB_PASSWORD=revel-password
REDIS_HOST=redis

# Mailpit captures everything; live_emails is flipped True post-bootstrap by
# the workflow (SiteSettings singleton) so addresses aren't scrambled.
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=False

# Suite contract: Celery inline so exports/auto-eval complete synchronously.
CELERY_TASK_ALWAYS_EAGER=True

# The FE preview under test.
BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173
# DEBUG=False disables CORS_ALLOW_ALL — the preview origin must be explicit.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Parallel Playwright workers hammer auth endpoints.
DISABLE_THROTTLING=True

# django-silk profiling deadlocks Postgres under parallel load (known local
# source of transient 500s) — keep it off in CI.
SILK_PROFILER=False
SILKY_PYTHON_PROFILER=False
