# Backend API URL (read at RUNTIME via $env/dynamic/public, not baked into the
# build) — set this when running the container/server to point the frontend at
# your backend. Defaults to http://localhost:8000 if unset.
PUBLIC_API_URL=http://localhost:8000

# Backend URL for server-side operations (e.g., API client generation)
BACKEND_URL=http://localhost:8000

# Frontend version (displayed in footer)
# In production, this is set by the Docker build from the git tag
# In development, it defaults to 'dev'
PUBLIC_VERSION=dev

# Google OAuth (if using)
PUBLIC_GOOGLE_CLIENT_ID=

# Environment
NODE_ENV=development

# IndexNow (SEO rapid re-crawl notifications to Bing/Yandex)
INDEXNOW_KEY=
INDEXNOW_TRIGGER_SECRET=

# Search Console verification
PUBLIC_GOOGLE_SITE_VERIFICATION=
PUBLIC_BING_SITE_VERIFICATION=
