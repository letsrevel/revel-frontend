{
	"name": "revel-frontend",
	"version": "1.68.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "svelte-kit sync && vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint . --max-warnings 0",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"generate:api": "node scripts/generate-api-client.js",
		"paraglide:compile": "node scripts/compile-i18n.js",
		"i18n:validate": "node scripts/validate-translations.js",
		"i18n:check-imports": "bash scripts/check-i18n-imports.sh",
		"i18n:hardcoded": "node scripts/check-i18n-hardcoded.mjs",
		"i18n:compile": "pnpm paraglide:compile && pnpm i18n:validate",
		"audit:images": "tsx scripts/audit-image-alt.ts"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.12.1",
		"@eslint/js": "^10.0.1",
		"@hey-api/openapi-ts": "^0.99.0",
		"@inlang/paraglide-js": "^2.20.2",
		"@lucide/svelte": "^1.23.0",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.69.2",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/typography": "^0.5.19",
		"@testing-library/jest-dom": "^6",
		"@testing-library/svelte": "^5.4.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^22.20.1",
		"@types/qrcode": "^1.5.5",
		"@types/testing-library__jest-dom": "^6.0.0",
		"@typescript-eslint/eslint-plugin": "^8.63.0",
		"@typescript-eslint/parser": "^8.63.0",
		"@vitest/ui": "^4.1.10",
		"autoprefixer": "^10.5.2",
		"bits-ui": "^2.18.1",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"glob": "^13.0.6",
		"globals": "^17.7.0",
		"jsdom": "^29.1.1",
		"otplib": "^13.4.1",
		"postcss": "^8.5.16",
		"prettier": "~3.9.4",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.2",
		"tailwindcss": "^3.4.17",
		"tslib": "^2.8.1",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.63.0",
		"vite": "^8.1.3",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"@fontsource-variable/nata-sans": "^5.2.2",
		"@tanstack/svelte-query": "^6.1.36",
		"@tiptap/core": "^3.27.3",
		"@tiptap/extension-hard-break": "^3.27.3",
		"@tiptap/extension-placeholder": "^3.27.3",
		"@tiptap/markdown": "^3.27.3",
		"@tiptap/starter-kit": "^3.27.3",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"heic2any": "^0.0.4",
		"html5-qrcode": "^2.3.8",
		"isomorphic-dompurify": "^3.18.0",
		"marked": "^18.0.5",
		"mode-watcher": "^1.1.0",
		"prom-client": "^15.1.3",
		"qrcode": "^1.5.4",
		"svelte-dnd-action": "^0.9.69",
		"svelte-easy-crop": "^5.0.1",
		"svelte-sonner": "^1.0.5",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"zod": "^4.4.3"
	},
	"engines": {
		"node": ">=22.13.0",
		"pnpm": ">=11.0.0"
	},
	"packageManager": "pnpm@11.6.0"
}
