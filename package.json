{
	"name": "revel-frontend",
	"version": "1.64.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "svelte-kit sync && vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"generate:api": "node scripts/generate-api-client.js",
		"paraglide:compile": "node scripts/compile-i18n.js",
		"i18n:validate": "node scripts/validate-translations.js",
		"i18n:check-imports": "bash scripts/check-i18n-imports.sh",
		"i18n:hardcoded": "node scripts/check-i18n-hardcoded.mjs",
		"i18n:compile": "pnpm paraglide:compile && pnpm i18n:validate",
		"audit:images": "tsx scripts/audit-image-alt.ts"
	},
	"devDependencies": {
		"@eslint/js": "^9.17.0",
		"@hey-api/openapi-ts": "^0.99.0",
		"@inlang/paraglide-js": "^2.4.0",
		"@lucide/svelte": "^0.482.0",
		"@playwright/test": "^1.49.0",
		"@sveltejs/adapter-node": "^5.4.0",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@testing-library/jest-dom": "^6",
		"@testing-library/svelte": "^5.2.8",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^22.10.2",
		"@types/qrcode": "^1.5.5",
		"@types/testing-library__jest-dom": "^6.0.0",
		"@typescript-eslint/eslint-plugin": "^8.17.0",
		"@typescript-eslint/parser": "^8.17.0",
		"@vitest/ui": "^4.1.9",
		"autoprefixer": "^10.4.20",
		"bits-ui": "^1.8.0",
		"eslint": "^9.17.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.46.1",
		"glob": "^13.0.6",
		"globals": "^15.13.0",
		"jsdom": "^29.1.1",
		"postcss": "^8.5.10",
		"prettier": "~3.6.2",
		"prettier-plugin-svelte": "^3.3.2",
		"prettier-plugin-tailwindcss": "^0.6.9",
		"svelte": "^5.55.7",
		"svelte-check": "^4.1.1",
		"tailwindcss": "^3.4.17",
		"tslib": "^2.8.1",
		"tsx": "^4.21.0",
		"typescript": "^5.7.2",
		"typescript-eslint": "^8.46.3",
		"vite": "^6.4.2",
		"vitest": "^3.2.6"
	},
	"dependencies": {
		"@fontsource-variable/nata-sans": "^5.2.2",
		"@tanstack/svelte-query": "^6.0.3",
		"@tiptap/core": "^3.27.1",
		"@tiptap/extension-hard-break": "^3.27.1",
		"@tiptap/extension-placeholder": "^3.27.1",
		"@tiptap/markdown": "^3.27.1",
		"@tiptap/starter-kit": "^3.27.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"heic2any": "^0.0.4",
		"html5-qrcode": "^2.3.8",
		"isomorphic-dompurify": "^3.18.0",
		"lucide-svelte": "^0.469.0",
		"marked": "^18.0.5",
		"mode-watcher": "^1.1.0",
		"prom-client": "^15.1.3",
		"qrcode": "^1.5.4",
		"svelte-dnd-action": "^0.9.69",
		"svelte-easy-crop": "^5.0.1",
		"svelte-sonner": "^1.0.5",
		"sveltekit-superforms": "^2.30.2",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^0.2.1",
		"zod": "^3.24.1"
	},
	"engines": {
		"node": ">=22.13.0",
		"pnpm": ">=11.0.0"
	},
	"packageManager": "pnpm@11.6.0"
}
